# Market Cockpit earnings worker — environment variables

# Where to push the prepared payload (your Vercel ingest endpoint)
INGEST_URL=https://market-cockpit.vercel.app/api/v1/earnings/calendar/ingest

# Shared secret protecting the ingest endpoint (must match Vercel EARNINGS_INGEST_SECRET)
INGEST_SECRET=change-me-to-a-random-string

# Upstash KV (only used for the optional health-check key — main writes go via ingest)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Scrape cadence (only used in loop mode)
SCRAPE_INTERVAL_MIN=30

# Optional: filing-date window
LOOKBACK_DAYS=70
LOOKAHEAD_DAYS=14

# Optional: which sources to enable (comma-separated). Order = priority.
# Worker tries each in order and uses the first that returns >=1 row per date window.
ACTIVE_SOURCES=nse,bse,trendlyne,tickertape

# Optional: proxy for Tier 2 residential rotation. Format: http://user:pass@host:port
HTTP_PROXY=

# Optional: Sentry / Axiom webhook for crash reports
ERROR_WEBHOOK=
