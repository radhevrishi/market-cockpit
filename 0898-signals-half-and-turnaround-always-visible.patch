         )}
 
         {/* ═══════════════ WHAT CHANGED TODAY ═══════════════════════════ */}
@@ -2746,7 +2769,7 @@ export default function HomeDashboard() {
                 if (a._inUniverse !== b._inUniverse) return a._inUniverse ? -1 : 1;
                 return 0;
