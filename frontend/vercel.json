{
  "_comment_p0703_disabled_crons": "concall-intel-warm + concall-intel-snapshot DISABLED until June 1 to escape free-tier Fluid CPU overage. Live-feed KV TTL was bumped from 2-10min to 30-60min so users hit cache anyway. To re-enable later, add { 'path': '/api/v1/cron/concall-intel-warm', 'schedule': '30 3 * * 1' } (Mondays only).",
  "crons": [
    {
      "path": "/api/bot/movers-alert?mode=full",
      "schedule": "35 4 * * 1-5"
    },
    {
      "path": "/api/bot/watchlist-alert?mode=full",
      "schedule": "50 4 * * 1-5"
    },
    {
      "path": "/api/market/intelligence/compute",
      "schedule": "0 4 * * 1-5"
    },
    {
      "path": "/api/market/earnings-guidance/ingest",
      "schedule": "15 4 * * 1-5"
    },
    {
      "path": "/api/v1/cron/refresh-earnings-calendar",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/bot/eo-blockbuster-alert",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/bot/eo-blockbuster-alert",
      "schedule": "30 15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://market-cockpit-api.onrender.com/api/v1/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
