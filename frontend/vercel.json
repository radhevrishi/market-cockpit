{
  "crons": [
    {
      "path": "/api/bot/movers-alert?secret=mc-bot-2026&mode=full",
      "schedule": "35 4 * * 1-5"
    },
    {
      "path": "/api/bot/movers-alert?secret=mc-bot-2026&mode=full",
      "schedule": "35 9 * * 1-5"
    },
    {
      "path": "/api/bot/watchlist-alert?secret=mc-bot-2026&mode=full",
      "schedule": "50 4 * * 1-5"
    },
    {
      "path": "/api/bot/watchlist-alert?secret=mc-bot-2026&mode=full",
      "schedule": "50 9 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://market-cockpit-api.onrender.com/api/v1/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
