From 7b5ef0d5dfbc77f02f0d0b99530fa39ef9a26b34 Mon Sep 17 00:00:00 2001
From: radhevrishi <radhev.232@gmail.com>
Date: Tue, 26 May 2026 10:07:20 +0000
Subject: [PATCH] patch 0880: tone-signal best-match + boilerplate/TOC +
 duplicate-value guidance dedup
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Concall AI ToneSignals + Top-Quotes had three remaining noise sources
that the NGL Fine Chem audit surfaced:

1. captureSignals used .find() to pick the FIRST sentence containing a
   phrase. For "record" that picked the cover-letter "...kindly take the
   information on record." line and surfaced it under "↑ record" — a
   POSITIVE signal label. Now picks the highest-scoring sentence among
   matches (scoreSentence already hard-rejects boilerplate at -100), and
   requires the winning score ≥ 1.

2. isBoilerplate missed several Indian cover-letter closings:
     - "kindly take (the information) on record"
     - "also being made available on (the Company website)"
     - "You are requested to (kindly take...)"
     - "Encl:"
     - "For COMPANY LIMITED" sign-off lines
     - inline-bracketed URLs from markdown extraction
     - "The above presentation"

3. isTableNoise missed TOC fragments like "04 Q4 & FY26 Highlights Pg."
   New rule: short sentence (<80 chars) with <=2 prose words AND a
   digit-prefix / Pg / Page / Contents marker is rejected.

Plus a guidance-display dedup in Auto-Val:

4. When extractGuidance attributes the SAME value across 4+ different
   FYs for the same metric, that pattern is the extractor matching a
   single number and stamping it on every FY token in the document.
   Real guidance varies year-over-year. Drop those clusters from the
   displayed panel. Kills the recurring noise: "Capacity Ramp 10% x 5",
   "EBITDA 14 Cr x 5", "CAGR 15-50% x 5".
---
 .../app/(dashboard)/auto-valuation/engine.ts  | 21 ++++++++-
 .../app/(dashboard)/auto-valuation/page.tsx   | 16 ++++++-
 frontend/src/lib/earnings/india-concall.ts    | 45 +++++++++++++++++--
 3 files changed, 76 insertions(+), 6 deletions(-)

diff --git a/frontend/src/app/(dashboard)/auto-valuation/engine.ts b/frontend/src/app/(dashboard)/auto-valuation/engine.ts
index 65392bb..87d106f 100644
--- a/frontend/src/app/(dashboard)/auto-valuation/engine.ts
+++ b/frontend/src/app/(dashboard)/auto-valuation/engine.ts
@@ -1466,7 +1466,7 @@ export async function buildReport(docs: ParsedDoc[]): Promise<AutoValuationRepor
   const _lsales = excelData?.latestSales || 0;
   const _lebitda = excelData?.latestEBITDA || 0;
   const _lpat = excelData?.latestPAT || 0;
-  const guidanceFiltered: GuidanceItem[] = allGuidance.filter((g) => {
+  const _step1: GuidanceItem[] = allGuidance.filter((g) => {
     // Always keep non-monetary metrics (margins, growth %, days, units, bps)
     if (g.unit !== '₹ Cr') return true;
     const v = g.point ?? g.high ?? g.low ?? 0;
@@ -1480,6 +1480,25 @@ export async function buildReport(docs: ParsedDoc[]): Promise<AutoValuationRepor
     }
     return true;
   });
+  // PATCH 0880 — Duplicate-value dedup. When the extractor finds the same
+  // numeric value attached to 4+ different FYs for the same metric, that's
+  // almost always a single noise-match being attributed to every FY token
+  // found in the document (the NGL Fine Chem case: "Capacity Ramp 10% × 5
+  // years"). Real guidance varies year-over-year. Drop those clusters.
+  const _valueCount = new Map<string, number>();
+  for (const g of _step1) {
+    const v = g.point ?? g.high ?? g.low ?? 0;
+    if (v <= 0) continue;
+    const key = `${g.metric}::${v.toFixed(2)}`;
+    _valueCount.set(key, (_valueCount.get(key) || 0) + 1);
+  }
+  const guidanceFiltered: GuidanceItem[] = _step1.filter((g) => {
+    const v = g.point ?? g.high ?? g.low ?? 0;
+    if (v <= 0) return true;
+    const key = `${g.metric}::${v.toFixed(2)}`;
+    // 4+ identical values for the same metric = noise pattern. Drop all.
+    return (_valueCount.get(key) || 0) < 4;
+  });
   const guidanceRejectedCount = allGuidance.length - guidanceFiltered.length;
   if (guidanceRejectedCount > 0) {
     rationale.push(`Guidance filter: ${guidanceRejectedCount} extractor matches dropped as implausible vs latest reported numbers (page-number noise / wrong-metric matches).`);
