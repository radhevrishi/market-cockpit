+
+/* ═══════════════════════════════════════════════════════════════════════════
+   PATCH 0075 — global theme override layer
+   ─────────────────────────────────────────────────────────────────────────
+   The dashboard pages use hardcoded inline-style hex colours (#0A0E1A,
+   #0D1B2E, #1A2840, #F5F7FA, etc.) instead of CSS variables. These don't
+   respond to ThemeContext changes on their own. This layer uses
+   [style*="..."] attribute selectors to override the most common ones when
+   data-theme="light" or "professional" is active.
+   Note: browsers normalize hex inline styles to rgb(R, G, B) at runtime,
+   so we match both forms.
+   ═══════════════════════════════════════════════════════════════════════════ */
+
+/* Body-level fallback so the page background flips even if no inline style matches */
+html[data-theme="light"] {
+  color-scheme: light;
+  background: #ffffff !important;
+}
+html[data-theme="light"] body {
+  background: #ffffff !important;
+  color: #0f172a;
+}
+html[data-theme="professional"] {
+  color-scheme: dark;
+  background: #000000 !important;
+}
+html[data-theme="professional"] body {
+  background: #000000 !important;
+  color: #e8e8e8;
+}
+
+/* ─── LIGHT THEME OVERRIDES ─────────────────────────────────────────── */
+
+/* Page bg #0A0E1A → white */
+html[data-theme="light"] [style*="#0A0E1A"],
+html[data-theme="light"] [style*="#0a0e1a"],
+html[data-theme="light"] [style*="rgb(10, 14, 26)"] {
+  background-color: #ffffff !important;
+  color: #0f172a !important;
+}
+/* Page bg #060E1A (markets ticker bg) */
+html[data-theme="light"] [style*="#060E1A"],
+html[data-theme="light"] [style*="#060e1a"],
+html[data-theme="light"] [style*="rgb(6, 14, 26)"] {
+  background-color: #f0f3f7 !important;
+}
+/* Header bg #0D1623, #0D1B2E → light panel */
+html[data-theme="light"] [style*="#0D1623"],
+html[data-theme="light"] [style*="#0d1623"],
+html[data-theme="light"] [style*="#0D1B2E"],
+html[data-theme="light"] [style*="#0d1b2e"],
+html[data-theme="light"] [style*="#111B35"],
+html[data-theme="light"] [style*="#111b35"],
+html[data-theme="light"] [style*="rgb(13, 22, 35)"],
+html[data-theme="light"] [style*="rgb(13, 27, 46)"],
+html[data-theme="light"] [style*="rgb(17, 27, 53)"] {
+  background-color: #f7f8fa !important;
+  border-color: rgba(0,0,0,0.08) !important;
+}
+/* Inner panel #1A2840, #1E2D45, #1A2B3C → softer light panel */
+html[data-theme="light"] [style*="#1A2840"],
+html[data-theme="light"] [style*="#1a2840"],
+html[data-theme="light"] [style*="#1E2D45"],
+html[data-theme="light"] [style*="#1e2d45"],
+html[data-theme="light"] [style*="#1A2B3C"],
+html[data-theme="light"] [style*="#1a2b3c"],
+html[data-theme="light"] [style*="#1e293b"],
+html[data-theme="light"] [style*="rgb(26, 40, 64)"],
+html[data-theme="light"] [style*="rgb(30, 45, 69)"] {
+  background-color: #f0f3f7 !important;
+  border-color: rgba(0,0,0,0.10) !important;
+  color: #0f172a;
+}
+/* Primary text #F5F7FA → dark text */
+html[data-theme="light"] [style*="#F5F7FA"],
+html[data-theme="light"] [style*="#f5f7fa"],
+html[data-theme="light"] [style*="#E6EDF3"],
+html[data-theme="light"] [style*="#e6edf3"],
+html[data-theme="light"] [style*="rgb(245, 247, 250)"],
+html[data-theme="light"] [style*="rgb(230, 237, 243)"] {
+  color: #0f172a !important;
+}
+/* Muted text #94A3B8, #6B7A8D, #8A95A3 → mid-slate */
+html[data-theme="light"] [style*="#94A3B8"],
+html[data-theme="light"] [style*="#94a3b8"],
+html[data-theme="light"] [style*="#6B7A8D"],
+html[data-theme="light"] [style*="#6b7a8d"],
+html[data-theme="light"] [style*="#8A95A3"],
+html[data-theme="light"] [style*="#8a95a3"],
+html[data-theme="light"] [style*="rgb(148, 163, 184)"],
+html[data-theme="light"] [style*="rgb(107, 122, 141)"] {
+  color: #475569 !important;
+}
+/* Faint text #4A5B6C, #C9D4E0 */
+html[data-theme="light"] [style*="#4A5B6C"],
+html[data-theme="light"] [style*="#4a5b6c"],
+html[data-theme="light"] [style*="#C9D4E0"],
+html[data-theme="light"] [style*="#c9d4e0"],
+html[data-theme="light"] [style*="rgb(74, 91, 108)"] {
+  color: #64748b !important;
+}
+/* Accent blue #0F7ABF / #38A9E8 — keep but tone down */
+html[data-theme="light"] [style*="#0F7ABF"],
+html[data-theme="light"] [style*="#0f7abf"] {
+  color: #0369a1 !important;
+}
+/* Body text fallback */
+html[data-theme="light"] [style*="#CBD5E1"],
+html[data-theme="light"] [style*="#cbd5e1"] {
+  color: #334155 !important;
+}
+
+/* ─── PROFESSIONAL THEME OVERRIDES (Bloomberg-terminal black + orange) ── */
+
+/* Page bg #0A0E1A → pure black */
+html[data-theme="professional"] [style*="#0A0E1A"],
+html[data-theme="professional"] [style*="#0a0e1a"],
+html[data-theme="professional"] [style*="rgb(10, 14, 26)"] {
+  background-color: #000000 !important;
+  color: #e8e8e8 !important;
+}
+html[data-theme="professional"] [style*="#060E1A"],
+html[data-theme="professional"] [style*="#060e1a"] {
+  background-color: #000000 !important;
+}
+/* Header / panel #0D1623, #0D1B2E → dark grey */
+html[data-theme="professional"] [style*="#0D1623"],
+html[data-theme="professional"] [style*="#0d1623"],
+html[data-theme="professional"] [style*="#0D1B2E"],
+html[data-theme="professional"] [style*="#0d1b2e"],
+html[data-theme="professional"] [style*="#111B35"],
+html[data-theme="professional"] [style*="#111b35"] {
+  background-color: #0f0f0f !important;
+  border-color: rgba(255,165,0,0.10) !important;
+}
+/* Inner panel borders */
+html[data-theme="professional"] [style*="#1A2840"],
+html[data-theme="professional"] [style*="#1a2840"],
+html[data-theme="professional"] [style*="#1E2D45"],
+html[data-theme="professional"] [style*="#1e2d45"],
+html[data-theme="professional"] [style*="#1A2B3C"],
+html[data-theme="professional"] [style*="#1a2b3c"] {
+  background-color: #161616 !important;
+  border-color: rgba(255,165,0,0.20) !important;
+}
+/* Primary accent: replace blue gradient with orange in pro theme */
+html[data-theme="professional"] [style*="#0F7ABF"],
+html[data-theme="professional"] [style*="#0f7abf"] {
+  color: #ffa500 !important;
+}
+html[data-theme="professional"] [style*="#06B6D4"],
+html[data-theme="professional"] [style*="#06b6d4"] {
+  color: #ff8800 !important;
+}
+/* Text colors stay readable on black */
+html[data-theme="professional"] [style*="#F5F7FA"],
+html[data-theme="professional"] [style*="#f5f7fa"] {
+  color: #e8e8e8 !important;
+}
+html[data-theme="professional"] [style*="#94A3B8"],
+html[data-theme="professional"] [style*="#94a3b8"] {
+  color: #888888 !important;
+}
+html[data-theme="professional"] [style*="#4A5B6C"],
+html[data-theme="professional"] [style*="#4a5b6c"] {
+  color: #555555 !important;
+}
+html[data-theme="professional"] {
+  font-family: "Roboto Mono", "SF Mono", Monaco, Consolas, monospace;
+}
+
+/* ─── LIGHT THEME — sidebar + scrollbar polish ──────────────────────── */
+html[data-theme="light"] aside {
+  background: #f7f8fa !important;
+  border-right: 1px solid rgba(0,0,0,0.08) !important;
+}
+html[data-theme="light"] header {
+  background: #ffffff !important;
+  border-bottom: 1px solid rgba(0,0,0,0.08) !important;
+}
+
+/* ─── PROFESSIONAL — Bloomberg-style polish ──────────────────────────── */
+html[data-theme="professional"] aside {
+  background: #0a0a0a !important;
+  border-right: 1px solid rgba(255,165,0,0.10) !important;
+}
+html[data-theme="professional"] header {
+  background: #0a0a0a !important;
+  border-bottom: 1px solid rgba(255,165,0,0.20) !important;
+}
+
+/* No transitions on theme change body — looks janky on slow devices */
+html[data-theme] body {
+  transition: background-color 0.15s ease;
+}
+
+/* ═══════════════════════════════════════════════════════════════════════════
+   PATCH 0075 — kill the narrow maxWidth gutters
+   ─────────────────────────────────────────────────────────────────────────
+   Many pages wrap content in <div style={{maxWidth:1000-1200, margin:'0 auto'}}>
+   which leaves big dark gutters on wide screens. Force any direct-child
+   wrapper of <main> to fill the available width up to 1800px.
+   ═══════════════════════════════════════════════════════════════════════════ */
+main > div[style*="margin: 0 auto"],
+main > div[style*="margin:0 auto"] {
+  max-width: 1800px !important;
+  width: 100% !important;
+}
+/* Some pages nest one more level deep */
+main > div > div[style*="margin: 0 auto"][style*="max-width"],
+main > div > div[style*="margin:0 auto"][style*="maxWidth"] {
+  max-width: 1800px !important;
+  width: 100% !important;
+}
+/* Strategic Visibility / Multibagger / Earnings AI all use this pattern */
+main [style*="maxWidth: 1100"],
+main [style*="maxWidth:1100"],
+main [style*="max-width: 1100"],
+main [style*="maxWidth: 1200"],
+main [style*="maxWidth:1200"],
+main [style*="max-width: 1200"],
+main [style*="maxWidth: 1400"],
+main [style*="maxWidth:1400"],
+main [style*="max-width: 1400"] {
+  max-width: 1800px !important;
+}
+
+/* Keep modal / drawer maxWidths intact (they should stay narrow) */
+main aside [style*="maxWidth"],
+main [role="dialog"] [style*="maxWidth"] {
+  max-width: revert !important;
+}
