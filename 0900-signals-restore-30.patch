From 10a2fb21bb1382345689fcdb0cc3e33ee0d9fb98 Mon Sep 17 00:00:00 2001
From: radhevrishi <radhev.232@gmail.com>
Date: Tue, 26 May 2026 13:04:58 +0000
Subject: [PATCH] patch 0900: restore Signals SHOWN cap to 30

User feedback: 15 felt too short; 30 was the right cap. Reverting the
0898 reduction. The Turnaround block at the top of the page handles
its own space; no need to compress Signals to make room.
---
 frontend/src/app/(dashboard)/page.tsx | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/frontend/src/app/(dashboard)/page.tsx b/frontend/src/app/(dashboard)/page.tsx
index bf802cc..5c0237b 100644
--- a/frontend/src/app/(dashboard)/page.tsx
+++ b/frontend/src/app/(dashboard)/page.tsx
@@ -2795,7 +2795,7 @@ export default function HomeDashboard() {
                 if (a._inUniverse !== b._inUniverse) return a._inUniverse ? -1 : 1;
                 return 0;
               });
-              const SHOWN = 15;  // PATCH 0898: 30 → 15 per user — half the rail, makes room for Turnaround block
+              const SHOWN = 30;  // PATCH 0900: restored 30 per user — 15 felt too short, 30 was right
               const items = enriched.slice(0, SHOWN);
               return (
                 <div style={{ display: 'flex', flexDirection: 'column', gap: 3, flex: 1, minHeight: 0 }}>
-- 
