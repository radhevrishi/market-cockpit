+html[data-theme="light"] [style*="#0D1117"],
+html[data-theme="light"] [style*="#0a0f1a"],
+html[data-theme="light"] [style*="#0A0F1A"],
+html[data-theme="light"] [style*="#060a14"],
+html[data-theme="light"] [style*="#060A14"],
+html[data-theme="light"] [style*="#13131a"],
+html[data-theme="light"] [style*="#13131A"] {
   background-color: #ffffff !important;
   color: #0f172a !important;
 }
@@ -307,7 +316,7 @@ html[data-theme="light"] [style*="rgb(17, 27, 53)"] {
   background-color: #f7f8fa !important;
   border-color: rgba(0,0,0,0.08) !important;
 }
-/* Inner panel #1A2840, #1E2D45, #1A2B3C → softer light panel */
+/* Inner panel #1A2840, #1E2D45, #1A2B3C, #2A3B4C, #1A2540, #0A1422, #0A1628 etc */
 html[data-theme="light"] [style*="#1A2840"],
 html[data-theme="light"] [style*="#1a2840"],
 html[data-theme="light"] [style*="#1E2D45"],
@@ -315,6 +324,15 @@ html[data-theme="light"] [style*="#1e2d45"],
 html[data-theme="light"] [style*="#1A2B3C"],
 html[data-theme="light"] [style*="#1a2b3c"],
 html[data-theme="light"] [style*="#1e293b"],
+html[data-theme="light"] [style*="#1E293B"],
+html[data-theme="light"] [style*="#2A3B4C"],
+html[data-theme="light"] [style*="#2a3b4c"],
+html[data-theme="light"] [style*="#1A2540"],
+html[data-theme="light"] [style*="#1a2540"],
+html[data-theme="light"] [style*="#0A1422"],
+html[data-theme="light"] [style*="#0a1422"],
+html[data-theme="light"] [style*="#0A1628"],
+html[data-theme="light"] [style*="#0a1628"],
 html[data-theme="light"] [style*="rgb(26, 40, 64)"],
 html[data-theme="light"] [style*="rgb(30, 45, 69)"] {
   background-color: #f0f3f7 !important;
@@ -341,13 +359,38 @@ html[data-theme="light"] [style*="rgb(148, 163, 184)"],
 html[data-theme="light"] [style*="rgb(107, 122, 141)"] {
   color: #475569 !important;
 }
-/* Faint text #4A5B6C, #C9D4E0 */
+/* PATCH 0076: ALL faint text colors → readable dark slate on white.
+   These were near-invisible on white in patch 0075. */
 html[data-theme="light"] [style*="#4A5B6C"],
 html[data-theme="light"] [style*="#4a5b6c"],
 html[data-theme="light"] [style*="#C9D4E0"],
 html[data-theme="light"] [style*="#c9d4e0"],
+html[data-theme="light"] [style*="#8BA3C1"],
+html[data-theme="light"] [style*="#8ba3c1"],
+html[data-theme="light"] [style*="#8A95A3"],
+html[data-theme="light"] [style*="#8a95a3"],
+html[data-theme="light"] [style*="#7d8590"],
+html[data-theme="light"] [style*="#7D8590"],
+html[data-theme="light"] [style*="#475569"],
+html[data-theme="light"] [style*="#334155"],
+html[data-theme="light"] [style*="#3B4754"],
+html[data-theme="light"] [style*="#3b4754"],
 html[data-theme="light"] [style*="rgb(74, 91, 108)"] {
-  color: #64748b !important;
+  color: #334155 !important;        /* mid-dark slate — readable */
+}
+/* And brighter text colors that are too pale on white */
+html[data-theme="light"] [style*="#E6EDF3"],
+html[data-theme="light"] [style*="#e6edf3"],
+html[data-theme="light"] [style*="#E2E8F0"],
+html[data-theme="light"] [style*="#e2e8f0"],
+html[data-theme="light"] [style*="#F5F7FA"],
+html[data-theme="light"] [style*="#f5f7fa"] {
+  color: #0f172a !important;        /* near-black — primary heading */
+}
+/* Catch-all aggressive: any element whose inline style uses a near-white
+   text color in light mode loses readability — force it dark. */
+html[data-theme="light"] [style*="#FFFFFF"] {
+  color: #0f172a !important;
 }
 /* Accent blue #0F7ABF / #38A9E8 — keep but tone down */
 html[data-theme="light"] [style*="#0F7ABF"],
@@ -360,64 +403,127 @@ html[data-theme="light"] [style*="#cbd5e1"] {
   color: #334155 !important;
 }
 
-/* ─── PROFESSIONAL THEME OVERRIDES (Bloomberg-terminal black + orange) ── */
+/* ─── PROFESSIONAL THEME — Bloomberg-terminal black + orange + monospace ── */
+/* PATCH 0076: Make Pro VISIBLY distinct from Dark.
+   Dark = grey-blue panels (#0d1117, #161b22). Professional = pure black bg
+   with orange-tinted borders, all blue accents flipped to orange/amber,
+   monospace font everywhere. */
 
-/* Page bg #0A0E1A → pure black */
+/* Force pure black on EVERY common page background */
