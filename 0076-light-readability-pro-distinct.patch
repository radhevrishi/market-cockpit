+html[data-theme="professional"] body,
+html[data-theme="professional"] * {
+  font-family: "Roboto Mono", "SF Mono", "Menlo", Monaco, Consolas, monospace !important;
+}
+/* Tighter letter spacing characteristic of Bloomberg terminals */
 html[data-theme="professional"] {
-  font-family: "Roboto Mono", "SF Mono", Monaco, Consolas, monospace;
+  letter-spacing: 0.01em;
 }
+/* Aggressive: any element with #ffffff text in professional → keep white but
+   add subtle text-shadow for terminal feel — actually skip, keep simple. */
 
 /* ─── LIGHT THEME — sidebar + scrollbar polish ──────────────────────── */
 html[data-theme="light"] aside {
@@ -444,6 +550,27 @@ html[data-theme] body {
   transition: background-color 0.15s ease;
 }
 
+/* ─── PATCH 0076: SAFETY NET — force main scroll container bg ─────────
+   Even if specific page-level inline styles slip through, force the
+   <main> container to show the theme background. */
+html[data-theme="light"] main {
+  background: #ffffff !important;
+  color: #0f172a !important;
+}
+html[data-theme="professional"] main {
+  background: #000000 !important;
+  color: #ffcc66 !important;
+}
+/* Force any direct child of main that has its own bg to inherit */
+html[data-theme="light"] main > div {
+  background-color: transparent !important;
+}
+html[data-theme="professional"] main > div {
+  background-color: transparent !important;
+}
+/* But cards INSIDE main keep their bg overrides from the rules above —
+   the [style*=""] selectors are more specific and still apply. */
+
