+    .sort((a: any, b: any) => (b.score ?? 0) - (a.score ?? 0));
+  const usaInTier1 = () => tier1.filter(t => (t as any).market === 'US').length;
+  if (usaQualified.length > 0 && usaInTier1() < TIER1_US_MIN) {
+    const haveSyms = new Set(tier1.map(t => symKey(t.symbol)));
