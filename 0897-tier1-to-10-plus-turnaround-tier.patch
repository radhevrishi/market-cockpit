+        .map((t, i) => ({ t, i }))
+        .filter(x => !x.t.cbConfirmed)
+        .sort((a, b) => (a.t.score ?? 0) - (b.t.score ?? 0))[0]?.i ?? -1;
+      if (dropIdx < 0) break;
+      tier1.splice(dropIdx, 1);
+    }
+    tier1 = [...tier1, ...usaTopUp];
+  }
+  // Fill any remaining slots with A-grade non-CB fillers.
+  if (tier1.length < TIER1_CAP) {
