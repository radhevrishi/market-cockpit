+      const triggerParts: string[] = [];
+      if (r.inBuyZone) triggerParts.push('BUY-ZONE');
+      if (r.concallScore >= 15) triggerParts.push('concall ≥15');
+      const horizon = r.phase === 2 || r.phase === 3 ? '2-4 quarters' : '4-8 quarters';
