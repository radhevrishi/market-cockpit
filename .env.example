# Market Cockpit — Environment Configuration
# Copy to .env and fill in your values

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./market_cockpit.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/market_cockpit

# Redis (optional — app works without Redis, AI/alerts will be degraded)
REDIS_URL=redis://localhost:6379/0

# Security — CHANGE THIS in production
SECRET_KEY=local-dev-secret-key-change-in-production-32chars

# AI Features (optional but recommended)
ANTHROPIC_API_KEY=
ALPHA_VANTAGE_KEY=

# Frontend URL for CORS
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Environment
ENVIRONMENT=development
