# Market Cockpit — Backend Configuration

# Database
# For local development (no PostgreSQL needed):
DATABASE_URL=sqlite+aiosqlite:///./market_cockpit.db
# For production with PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/market_cockpit

# Redis (optional — app works without Redis, cache/pub-sub will be degraded)
REDIS_URL=redis://localhost:6379/0

# Security — CHANGE THIS in production
SECRET_KEY=local-dev-secret-key-change-in-production-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Third-party APIs
ANTHROPIC_API_KEY=
ALPHA_VANTAGE_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Polling
NEWS_POLL_INTERVAL_SECONDS=180
ALERT_CHECK_INTERVAL_SECONDS=60

# AI Brief Times
AI_BRIEF_MORNING_IST=08:30
AI_BRIEF_CLOSE_EST=17:30

# Monitoring
SENTRY_DSN=
ENVIRONMENT=development
